<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal">

    <!-- 专辑封面 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardCover"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginTop="32dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        android:layout_gravity="center_horizontal">

        <ImageView
            android:id="@+id/ivCover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_music_note"/>

    </com.google.android.material.card.MaterialCardView>

    <!-- 动态频谱可视化 -->
    <LinearLayout
        android:id="@+id/vizContainer"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <View
            android:id="@+id/vizBar1"
            android:layout_width="6dp"
            android:layout_height="4dp"
            android:layout_marginHorizontal="2dp"
            android:background="@drawable/viz_bar_bg"/>

        <View
            android:id="@+id/vizBar2"
            android:layout_width="6dp"
            android:layout_height="4dp"
            android:layout_marginHorizontal="2dp"
            android:background="@drawable/viz_bar_bg"/>

        <View
            android:id="@+id/vizBar3"
            android:layout_width="6dp"
            android:layout_height="4dp"
            android:layout_marginHorizontal="2dp"
            android:background="@drawable/viz_bar_bg"/>

        <View
            android:id="@+id/vizBar4"
            android:layout_width="6dp"
            android:layout_height="4dp"
            android:layout_marginHorizontal="2dp"
            android:background="@drawable/viz_bar_bg"/>

        <View
            android:id="@+id/vizBar5"
            android:layout_width="6dp"
            android:layout_height="4dp"
            android:layout_marginHorizontal="2dp"
            android:background="@drawable/viz_bar_bg"/>

        <View
            android:id="@+id/vizBar6"
            android:layout_width="6dp"
            android:layout_height="4dp"
            android:layout_marginHorizontal="2dp"
            android:background="@drawable/viz_bar_bg"/>

        <View
            android:id="@+id/vizBar7"
            android:layout_width="6dp"
            android:layout_height="4dp"
            android:layout_marginHorizontal="2dp"
            android:background="@drawable/viz_bar_bg"/>

    </LinearLayout>

    <!-- 歌曲信息 -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="NovaBeat"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="20dp"
        android:maxLines="1"
        android:ellipsize="marquee"/>

    <TextView
        android:id="@+id/tvArtist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="开始播放音乐"
        android:textSize="14sp"
        android:textColor="?android:attr/textColorSecondary"
        android:gravity="center"
        android:layout_marginTop="4dp"/>

    <!-- 进度条 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp">

        <TextView
            android:id="@+id/tvCurrentPos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textSize="12sp"/>

        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"/>

        <TextView
            android:id="@+id/tvDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textSize="12sp"/>

    </LinearLayout>

    <!-- 控制按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPrev"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:icon="@drawable/ic_skip_previous"
            app:iconSize="28dp"
            app:iconTint="?attr/colorPrimary"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlayPause"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:icon="@drawable/ic_play"
            app:iconSize="36dp"
            app:iconTint="?attr/colorPrimary"
            app:iconGravity="textStart"
            android:layout_marginHorizontal="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:icon="@drawable/ic_skip_next"
            app:iconSize="28dp"
            app:iconTint="?attr/colorPrimary"/>

    </LinearLayout>

    <!-- 分享和下载按钮行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShareMain"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="分享"
            android:textSize="13sp"
            app:icon="@drawable/ic_share_new"
            app:iconGravity="textStart"
            app:iconSize="18dp"/>

    </LinearLayout>

    <!-- 播放队列 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="播放队列"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvQueue"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"/>

</LinearLayout>